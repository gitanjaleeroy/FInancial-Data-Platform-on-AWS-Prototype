{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "S3ObjectAccess",
			"Effect": "Allow",
			"Action": [
				"s3:GetObject",
				"s3:PutObject",
				"s3:DeleteObject"
			],
			"Resource": ["arn:aws:s3:::trading-data-lake-gitanjalee/*", 
			"arn:aws:s3:::test-gitanjaleeroy/*"]
		},
		{
			"Sid": "S3ListBucket",
			"Effect": "Allow",
			"Action": "s3:ListBucket",
			"Resource": ["arn:aws:s3:::trading-data-lake-gitanjalee",
			"arn:aws:s3:::test-gitanjaleeroy"]
		},
		{
			"Sid": "CloudWatchLogs",
			"Effect": "Allow",
			"Action": [
				"logs:CreateLogGroup",
				"logs:CreateLogStream",
				"logs:PutLogEvents"
			],
			"Resource": "*"
		}
	]
}
